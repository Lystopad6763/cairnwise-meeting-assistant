# Cairnwise — приклад конфігу. Скопіюй у .env і заповни значення.
# .env НЕ комітиться (він у .gitignore). Цей .example — комітиться як шаблон.

# HuggingFace токен — для gated-моделей діаризації (pyannote) і завантаження ваг.
#   Отримати: https://huggingface.co/settings/tokens  (роль: Read)
#   Прийняти умови на сторінці КОЖНОЇ моделі (інакше 401):
#     huggingface.co/pyannote/speaker-diarization-3.1
#     huggingface.co/pyannote/segmentation-3.0
#     huggingface.co/pyannote/speaker-diarization-community-1
#     huggingface.co/pyannote/wespeaker-voxceleb-resnet34-LM (Не потріно)
HF_TOKEN=

# (опц.) перенаправити кеш HuggingFace (інакше C:\Users\<you>\.cache\huggingface)
# HF_HOME=D:\hf-cache

# (опц.) локальна LLM через Ollama — за замовчуванням локально, ключ не потрібен
# OLLAMA_HOST=http://localhost:11434

# --- Інфраструктура з боку ХОСТА (STT-воркер + локальний uvicorn). ---
# Порти зміщені в docker-compose (postgres 5433, redis 6380, qdrant 6543), бо 5432/6379/6333
# на цій машині зайняті (нативний Postgres + контейнери інших проєктів) -> перевизнач ТУТ.
# Контейнер-API ці значення ігнорує (бере свої з compose `environment:`); .env в образ не йде.
DATABASE_URL=postgresql+psycopg://cairnwise:cairnwise@localhost:5433/cairnwise
REDIS_URL=redis://localhost:6380/0
QDRANT_URL=http://localhost:6543

# --- STT-воркер (Фаза 2-3). Стек зафіксовано бенчмарком треку D. ---
WHISPER_MODEL=small                         # на 4 GB GPU влазить лише small (medium/large-v3 -> OOM)
DIARIZER=pyannote/speaker-diarization-3.1   # альтернатива: ...-community-1
USE_GLOSSARY=1                              # 1 = вмикати глосарій-prompt (тех-терміни)

# --- Саммарі: локальне vs хмарне (вибір ЗА ПРИВАТНІСТЮ зустрічі). ---
# STT+діаризація ЗАВЖДИ локальні; у хмару йде ЛИШЕ текст саммарі (приватна зустріч -> ніколи).
SUMMARY_MODEL_LOCAL=neural-chat             # приватна зустріч -> Ollama (локально, $0)
SUMMARY_MODEL_CLOUD=gpt-4o-mini             # публічна зустріч -> OpenAI (краща якість)
# OPENAI_API_KEY=sk-...                      # встав свій ключ для хмарного режиму
OPENAI_API_KEY=